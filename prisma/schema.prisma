// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// LockPoint — Military Attendance System Schema
// ─────────────────────────────────────────────────────────────

/// Organizational unit (hierarchy: command → brigade → battalion → company → platoon → squad)
model Unit {
  id          String   @id @default(cuid())
  name        String
  type        String   // command | brigade | battalion | company | platoon | squad
  parentId    String?
  parent      Unit?    @relation("UnitHierarchy", fields: [parentId], references: [id])
  children    Unit[]   @relation("UnitHierarchy")
  commanderId String?
  commander   User?    @relation("UnitCommander", fields: [commanderId], references: [id])
  soldiers    User[]   @relation("UnitMembers")
  zones       GeofenceZone[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// System user — soldier, commander, or senior_commander
model User {
  id              String   @id @default(cuid())
  serviceNumber   String   @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            String   // soldier | commander | senior_commander
  rankCode        String
  rankLabel       String
  rankLevel       Int
  unitId          String
  unit            Unit     @relation("UnitMembers", fields: [unitId], references: [id])
  commandedUnits  Unit[]   @relation("UnitCommander")
  email           String?
  phone           String?

  // Location data (soldiers use plain Float, commanders use encrypted Bytes)
  currentStatus       String   @default("unknown") // in_base | out_of_base | unknown
  lastKnownLat        Float?   // Plain-text — soldiers only (null for commanders)
  lastKnownLng        Float?   // Plain-text — soldiers only (null for commanders)
  lastLocationUpdate  DateTime?

  // Encrypted location data — commanders only (ECIES via §9.10)
  encryptedLat        Bytes?   // ECIES-encrypted latitude
  encryptedLng        Bytes?   // ECIES-encrypted longitude
  encryptedLocNonce   String?  // Nonce/IV used for the AES-GCM encryption

  // Cryptographic identity (§9.10 Hardware Attestation)
  devicePublicKey     String?  // ECDSA P-256 public key (base64 DER) — set during device registration
  locationEncPubKey   String?  // ECDH P-256 key for encrypting own location data

  // Relations
  geofenceEvents  GeofenceEvent[]
  exitReports     ExitReport[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  notifications   Notification[]
  statusSnapshots StatusSnapshot[] @relation("StatusSnapshots")
  visibilityGrants  CommanderVisibilityGrant[] @relation("VisibilityReceived")
  visibilityTargets CommanderVisibilityGrant[] @relation("VisibilityGranted")
  permissions       UserPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Refresh token for JWT rotation
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Geofence zone definition
model GeofenceZone {
  id          String   @id @default(cuid())
  name        String
  description String?
  shapeType   String   // circle | polygon
  centerLat   Float?
  centerLng   Float?
  radiusMeters Float?
  vertices    String?  // JSON-encoded LatLng[] for polygons
  isActive    Boolean  @default(true)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  createdBy   String
  events      GeofenceEvent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Geofence transition event
model GeofenceEvent {
  id          String   @id @default(cuid())
  soldierId   String
  soldier     User     @relation(fields: [soldierId], references: [id])
  zoneId      String
  zone        GeofenceZone @relation(fields: [zoneId], references: [id])
  transition  String   // ENTER | EXIT | STAY
  lat         Float
  lng         Float
  accuracy    Float    // GPS accuracy in meters
  batteryLevel Int?
  exitReport  ExitReport?
  timestamp   DateTime @default(now())
}

/// Exit report — soldier's "where to?" submission
model ExitReport {
  id              String   @id @default(cuid())
  soldierId       String
  soldier         User     @relation(fields: [soldierId], references: [id])
  eventId         String   @unique
  event           GeofenceEvent @relation(fields: [eventId], references: [id])
  destination     String
  reason          String   // personal_leave | medical | official_duty | training | emergency | other
  freeText        String?
  estimatedReturn DateTime?
  createdAt       DateTime @default(now())
}

/// Immutable audit log — forensic record of every action
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // LOGIN | LOGOUT | CREATE_ZONE | UPDATE_STATUS | SUBMIT_REPORT | etc.
  resource  String?  // affected resource type
  resourceId String? // affected resource ID
  detail    String?  // JSON metadata
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// v0.4.0 — Smart Notifications
// ─────────────────────────────────────────────────────────────

/// In-app notification for commanders and soldiers
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // EXIT_NO_REPORT | UNKNOWN_STATUS | REPORT_REMINDER
  title     String
  body      String
  isRead    Boolean  @default(false)
  relatedId String?  // soldierId or eventId for context
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// v0.4.0 — BI / AI Data Layer
// ─────────────────────────────────────────────────────────────

/// Periodic snapshot of soldier status — captured by cron job
model StatusSnapshot {
  id         String   @id @default(cuid())
  soldierId  String
  soldier    User     @relation("StatusSnapshots", fields: [soldierId], references: [id])
  unitId     String
  status     String   // in_base | out_of_base | unknown
  lat        Float?
  lng        Float?
  accuracy   Float?
  capturedAt DateTime @default(now())

  @@index([soldierId, capturedAt])
  @@index([unitId, capturedAt])
}

/// Daily unit-level summary — aggregated nightly
model DailyUnitSummary {
  id               String   @id @default(cuid())
  unitId           String
  date             DateTime @db.Date
  totalPersonnel   Int
  avgInBase        Float
  avgOutOfBase     Float
  avgUnknown       Float
  totalExitEvents  Int
  totalEnterEvents Int
  unreportedExits  Int
  capturedAt       DateTime @default(now())

  @@unique([unitId, date])
  @@index([unitId, date])
}

// ─────────────────────────────────────────────────────────────
// Commander Location Visibility — Hierarchical Access Control
// ─────────────────────────────────────────────────────────────

/// Explicit permission for a commander to view another commander's encrypted location.
/// Includes ECDH key exchange material for end-to-end encrypted location sharing.
model CommanderVisibilityGrant {
  id                String   @id @default(cuid())
  grantedToId       String   // Commander who RECEIVES visibility
  grantedTo         User     @relation("VisibilityReceived", fields: [grantedToId], references: [id])
  targetCommanderId String   // Commander whose location becomes VISIBLE
  targetCommander   User     @relation("VisibilityGranted", fields: [targetCommanderId], references: [id])
  grantedById       String   // SC-001 who authorized this grant
  reason            String?  // Optional justification
  viewerPublicKey   String   // ECDH public key of the viewer (required for key exchange)
  ephemeralPubKey   String?  // Server-relayed ephemeral key for ECIES handshake
  encryptedViewKey  Bytes?   // Viewing key encrypted with viewer's public key
  createdAt         DateTime @default(now())
  expiresAt         DateTime? // Optional expiry for temporary grants
  isActive          Boolean  @default(true) // Marks if the grant is currently active

  @@unique([grantedToId, targetCommanderId, isActive])
  @@index([grantedToId])
}

// ─────────────────────────────────────────────────────────────
// RBAC Permission System — Zero Trust / PoLP
// ─────────────────────────────────────────────────────────────

/// Granular permission definition (seeded at deploy time).
/// Permissions are assigned to users via UserPermission, not directly.
model Permission {
  id          String  @id @default(cuid())
  code        String  @unique    // e.g., MANAGE_VISIBILITY_GRANTS
  label       String             // Human-readable Hebrew label
  category    String             // LOCATION | ZONES | ADMIN | REPORTS
  description String?
  assignments UserPermission[]
}

/// Assignment of a specific permission to a specific user.
/// Supports scope-limited access (via scopeUnitId) and auto-expiry.
model UserPermission {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  permissionCode String
  permission     Permission  @relation(fields: [permissionCode], references: [code])
  scopeUnitId    String?     // null = global scope, unitId = subtree-only
  grantedById    String      // Who assigned — separation of duties
  reason         String?     // Documented justification
  grantedAt      DateTime    @default(now())
  expiresAt      DateTime?   // Auto-revoke after this date

  @@unique([userId, permissionCode])
  @@index([userId])
}
